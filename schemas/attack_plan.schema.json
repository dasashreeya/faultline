{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faultline/attack_plan",
  "title": "AttackPlan",
  "description": "Ranked attacks. Tier 0: hand-curated JSON. Add-back 3: GPT-5.6 planner-lite emits the same shape.",
  "type": "object",
  "required": ["generated_by", "attacks"],
  "properties": {
    "generated_by": { "enum": ["curated", "gpt", "random"] },
    "attacks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rank", "scenario_id", "fault", "target", "hypothesis"],
        "properties": {
          "rank": { "type": "integer" },
          "scenario_id": { "type": "string" },
          "fault": { "type": "string", "description": "fault id from faults/library.py" },
          "target": { "type": "string", "description": "tool name to aim at" },
          "step_hint": { "type": ["integer", "null"] },
          "hypothesis": { "type": "string", "description": "why this will probably work — the demo's 'why' column" }
        }
      }
    }
  }
}
