{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faultline/run_record",
  "title": "RunRecord",
  "description": "One (scenario, seed, attempt) execution. The gauntlet writes the record; judge, scorer, report, and hardener consume it. planner_hypothesis is populated when an attack plan is active.",
  "type": "object",
  "required": ["run_id", "scenario_id", "seed", "attempt", "fault_schedule", "transcript", "end_state", "cost"],
  "properties": {
    "run_id": { "type": "string" },
    "scenario_id": { "type": "string" },
    "seed": { "type": "integer" },
    "attempt": { "type": "integer", "description": "hardening attempt index; 0 = pre-hardening baseline" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "fault_schedule": { "$ref": "faultline/fault_schedule" },
    "transcript": {
      "type": "array",
      "description": "Ordered events: llm/tool_call/tool_result/fault_injected/final_answer",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "enum": ["llm", "tool_call", "tool_result", "fault_injected", "final_answer", "exception"] },
          "tool": { "type": "string" },
          "args_hash": { "type": "string" },
          "content": {},
          "fault": { "type": "string" }
        }
      }
    },
    "end_state": { "type": "object", "description": "mock-backend snapshot after the run" },
    "detectors": {
      "type": "object",
      "properties": {
        "loop": { "type": "boolean" },
        "budget_overrun": { "type": "boolean" },
        "crash": { "type": "boolean" },
        "end_state_ok": { "type": "boolean" }
      }
    },
    "judge": {
      "type": "object",
      "required": ["grade", "weight", "reasoning"],
      "properties": {
        "grade": { "enum": ["A", "B", "C", "D", "E"] },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "reasoning": { "type": "string" }
      }
    },
    "planner_hypothesis": { "type": ["string", "null"], "description": "planner explanation for the selected attack, or null when no plan is active" },
    "cost": {
      "type": "object",
      "properties": {
        "tokens": { "type": "integer" },
        "tool_calls": { "type": "integer" },
        "wall_time_s": { "type": "number" }
      }
    }
  }
}
